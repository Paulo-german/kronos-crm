# -----------------------------------------------------------------------------
# KRONOS CRM - ENVIRONMENT VARIABLES
# Copy this file to .env and fill in the values
# -----------------------------------------------------------------------------

# 1. SUPABASE DATABASE (Pooler - Transaction Mode, Port 6543)
DATABASE_URL="postgresql://postgres.[project-ref]:[password]@aws-1-sa-east-1.pooler.supabase.com:6543/postgres?pgbouncer=true"

# 2. DIRECT CONNECTION (Migrations only - Session Mode, Port 5432)
DIRECT_URL="postgresql://postgres.[project-ref]:[password]@aws-1-sa-east-1.pooler.supabase.com:5432/postgres"

# 3. SUPABASE API (Auth & Client)
NEXT_PUBLIC_SUPABASE_URL="https://[project-ref].supabase.co"
NEXT_PUBLIC_SUPABASE_ANON_KEY="your-anon-key"
SUPABASE_SERVICE_ROLE_KEY="your-service-role-key"

# 4. APP URL (Required - your production domain or localhost for dev)
NEXT_PUBLIC_APP_URL="http://localhost:3000"

# 5. STRIPE (Billing)
STRIPE_SECRET_KEY="sk_test_..."
STRIPE_WEBHOOK_SECRET="whsec_..."
NEXT_PUBLIC_STRIPE_PUBLISHABLE_KEY="pk_test_..."

# Light Plan
STRIPE_LIGHT_PRICE_ID=""
STRIPE_LIGHT_ANNUAL_PRICE_ID=""
NEXT_PUBLIC_STRIPE_LIGHT_PRICE_ID=""
NEXT_PUBLIC_STRIPE_LIGHT_ANNUAL_PRICE_ID=""

# Essential Plan
STRIPE_ESSENTIAL_PRICE_ID=""
STRIPE_ESSENTIAL_ANNUAL_PRICE_ID=""
NEXT_PUBLIC_STRIPE_ESSENTIAL_PRICE_ID=""
NEXT_PUBLIC_STRIPE_ESSENTIAL_ANNUAL_PRICE_ID=""

# Scale Plan
STRIPE_SCALE_PRICE_ID=""
STRIPE_SCALE_ANNUAL_PRICE_ID=""
NEXT_PUBLIC_STRIPE_SCALE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_SCALE_ANNUAL_PRICE_ID=""

# Enterprise Plan
STRIPE_ENTERPRISE_PRICE_ID=""
STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=""
NEXT_PUBLIC_STRIPE_ENTERPRISE_PRICE_ID=""
NEXT_PUBLIC_STRIPE_ENTERPRISE_ANNUAL_PRICE_ID=""

# Product IDs (optional, used in seed)
STRIPE_LIGHT_PRODUCT_ID=""
STRIPE_ESSENTIAL_PRODUCT_ID=""
STRIPE_SCALE_PRODUCT_ID=""
STRIPE_ENTERPRISE_PRODUCT_ID=""

# 6. RESEND (Transactional Emails)
RESEND_API_KEY="re_..."

# 7. GOOGLE reCAPTCHA v3
NEXT_PUBLIC_RECAPTCHA_SITE_KEY=""
RECAPTCHA_SECRET_KEY=""

# 8. EVOLUTION API (WhatsApp)
EVOLUTION_WEBHOOK_SECRET="your-evolution-webhook-secret"
EVOLUTION_API_URL="https://evo.seudominio.com"
EVOLUTION_API_KEY="your-evolution-api-key"

# 9. REDIS (Deduplication - Hetzner VPS)
REDIS_URL="redis://user:password@your-hetzner-vps:6379"

# 9b. META WHATSAPP CLOUD API
NEXT_PUBLIC_META_APP_ID=
META_APP_SECRET=
NEXT_PUBLIC_META_CONFIG_ID=
META_API_VERSION=v25.0
META_WEBHOOK_VERIFY_TOKEN=

# 10. TRIGGER.DEV (Background Tasks - Cloud)
TRIGGER_SECRET_KEY="tr_dev_..."
TRIGGER_PROJECT_ID="proj_..."

# 11. OPENROUTER (LLM Gateway)
OPENROUTER_API_KEY="sk-or-v1-..."

# 12. LANGFUSE (LLM Observability)
LANGFUSE_SECRET_KEY="sk-lf-..."
LANGFUSE_PUBLIC_KEY="pk-lf-..."
LANGFUSE_BASE_URL="https://cloud.langfuse.com"

# 13. GOOGLE OAUTH (Calendar Integration)
GOOGLE_CLIENT_ID=""
GOOGLE_CLIENT_SECRET=""
GOOGLE_REDIRECT_URI="http://localhost:3000/api/integrations/google/callback"
ENCRYPTION_KEY=""

# 14. Z-API (WhatsApp - credenciais per-inbox no banco, so o webhook secret eh env var)
ZAPI_WEBHOOK_SECRET="your-zapi-webhook-secret"

# 15. BACKBLAZE B2 (File Storage - S3-compatible)
B2_KEY_ID=""
B2_APP_KEY=""
B2_ENDPOINT="https://s3.us-west-004.backblazeb9.com"
B2_REGION="us-west-007"
B2_BUCKET_NAME="kronos-media"
B2_PUBLIC_URL="https://f004.backblazb2.com/file/kronos-media"
