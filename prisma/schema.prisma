  @@map("agent_test_messages")
}

model AgentExecution {
  id               String                @id @default(uuid())
  // Nullable: null quando a execução é do router embutido (não de um agent worker)
  agentId          String?               @map("agent_id")
  // Preenchido quando a execução é do router do AgentGroup
  agentGroupId     String?               @map("agent_group_id")
  organizationId   String                @map("organization_id")
  conversationId   String                @map("conversation_id")
  triggerMessageId String?               @map("trigger_message_id")
  status           AgentExecutionStatus
  startedAt        DateTime              @map("started_at")
  completedAt      DateTime?             @map("completed_at")
  durationMs       Int?                  @map("duration_ms")
  modelId          String?               @map("model_id")
  inputTokens      Int?                  @map("input_tokens")
  outputTokens     Int?                  @map("output_tokens")
  creditsCost      Int?                  @map("credits_cost")
  errorMessage     String?               @map("error_message")
  finishReason     String?               @map("finish_reason")
  metadata         Json?
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  agent        Agent?             @relation(fields: [agentId], references: [id], onDelete: Cascade)
  agentGroup   AgentGroup?        @relation(fields: [agentGroupId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  steps        AgentExecutionStep[]

  @@index([agentId, createdAt(sort: Desc)])
  @@index([agentGroupId, createdAt(sort: Desc)])
  @@index([organizationId, agentId, status])
  @@index([conversationId])
  @@map("agent_executions")
}

model AgentExecutionStep {
  id          String                   @id @default(uuid())
  executionId String                   @map("execution_id")
  order       Int
  type        AgentExecutionStepType
  status      AgentExecutionStepStatus
  toolName    String?                  @map("tool_name")
  input       Json?
  output      Json?
  durationMs  Int?                     @map("duration_ms")
  createdAt   DateTime                 @default(now()) @map("created_at")

  execution AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, order])
  @@map("agent_execution_steps")
}

model UserIntegration {
