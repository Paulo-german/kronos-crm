model Inbox {
  id                    String         @id @default(uuid())
  organizationId        String         @map("organization_id")
  name                  String
  channel               InboxChannel   @default(WHATSAPP)
  isActive              Boolean        @default(true) @map("is_active")
  evolutionInstanceName  String?        @unique @map("evolution_instance_name")
  evolutionInstanceId    String?        @map("evolution_instance_id")
  evolutionConnected     Boolean        @default(false) @map("evolution_connected")
  // Credenciais self-hosted por inbox (BYOI — Bring Your Own Instance)
  evolutionApiUrl        String?        @map("evolution_api_url")
  evolutionApiKey        String?        @map("evolution_api_key")
  evolutionWebhookSecret String?        @map("evolution_webhook_secret")
  agentId               String?        @map("agent_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  autoCreateDeal        Boolean        @default(true) @map("auto_create_deal")
  distributionUserIds   String[]       @map("distribution_user_ids") @db.Uuid
  pipelineId            String?        @map("pipeline_id") @db.Uuid
  connectionType        ConnectionType @default(EVOLUTION) @map("connection_type")
  metaAccessToken       String?        @map("meta_access_token")
  metaPhoneDisplay      String?        @map("meta_phone_display")
  metaPhoneNumberId     String?        @map("meta_phone_number_id")
  metaWabaId            String?        @map("meta_waba_id")
  // Identificadores Instagram (mutuamente exclusivos com metaPhoneNumberId)
  metaIgUserId          String?        @unique @map("meta_ig_user_id")
  metaIgPageId          String?        @map("meta_ig_page_id")
  metaIgUsername        String?        @map("meta_ig_username")
  zapiInstanceId        String?        @unique @map("zapi_instance_id")
  zapiToken             String?        @map("zapi_token")
  zapiClientToken       String?        @map("zapi_client_token")
  showAttendantName     Boolean        @default(false) @map("show_attendant_name")
  // Modo grupo (mutuamente exclusivo com agentId — validado na action)
  agentGroupId          String?        @map("agent_group_id")
  captureSourceId       String?        @map("capture_source_id")
  conversations         Conversation[]
  agent                 Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  agentGroup            AgentGroup?    @relation(fields: [agentGroupId], references: [id], onDelete: SetNull)
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  captureSource         CaptureSource? @relation(fields: [captureSourceId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@index([agentId])
  @@index([agentGroupId])
  @@index([metaPhoneNumberId])
  @@index([zapiInstanceId])
  @@index([metaIgUserId])
  @@index([captureSourceId])
  @@map("inboxes")
}

model Conversation {
  id                     String              @id @default(uuid())
  inboxId                String              @map("inbox_id")
  organizationId         String              @map("organization_id")
  contactId              String              @map("contact_id")
  dealId                 String?             @map("deal_id")
  // Responsável pela conversa — herdado do contato na criação, usado para filtro RBAC (MEMBER)
  assignedTo             String?             @map("assigned_to")
  channel                InboxChannel        @default(WHATSAPP)
  aiPaused               Boolean             @default(false) @map("ai_paused")
  pausedAt               DateTime?           @map("paused_at")
  remoteJid              String?             @map("remote_jid")
  summary                String?
  currentStepOrder       Int                 @default(0) @map("current_step_order")
  unreadCount            Int                 @default(0) @map("unread_count")
  // Role da última mensagem da conversa (denormalizado para filtro "não respondidos")
  lastMessageRole        String?             @map("last_message_role")
  // Fixar conversa no topo — null = não fixada, preenchido = fixada (serve como flag E timestamp)
  pinnedAt               DateTime?           @map("pinned_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  nextFollowUpAt         DateTime?           @map("next_follow_up_at")
  followUpCount          Int                 @default(0) @map("follow_up_count")
  lastCustomerMessageAt  DateTime?           @map("last_customer_message_at")
  // Worker ativo nesta conversa — campo de tracking leve sem FK (agente pode sair do grupo)
  activeAgentId          String?             @map("active_agent_id")
  // Status da conversa: OPEN por default, RESOLVED quando marcada manualmente
  status                 ConversationStatus  @default(OPEN)
  // Rastreamento de resolução — null quando status é OPEN
  resolvedAt             DateTime?           @map("resolved_at")
  resolvedBy             String?             @map("resolved_by")
  agentExecutions        AgentExecution[]
  events                 ConversationEvent[]
  labels                 ConversationLabelAssignment[]
  assignee               User?               @relation("ConversationAssignee", fields: [assignedTo], references: [id])
  contact                Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal                   Deal?               @relation(fields: [dealId], references: [id])
  inbox                  Inbox               @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages               Message[]

  @@unique([inboxId, contactId, channel])
  @@index([organizationId, inboxId])
  @@index([organizationId, assignedTo])
  @@index([contactId])
  @@index([remoteJid, inboxId])
  @@index([dealId])
  @@index([nextFollowUpAt, aiPaused])
  // Índice composto para a query "não respondidos": WHERE org = X AND last_message_role = 'user' ORDER BY updated_at DESC
  @@index([organizationId, lastMessageRole, updatedAt(sort: Desc)])
  // Índice composto para filtro por status no inbox: WHERE org = X AND status = Y ORDER BY updated_at DESC
  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@map("conversations")
}

model ConversationLabel {
