model Professional {
  id              String    @id @default(uuid())
  organizationId  String    @map("organization_id")
  // userId é opcional: profissional pode existir sem login no sistema
  userId          String?   @unique @map("user_id")
  name            String
  phone           String?
  email           String?   @map("email")
  bio             String?
  avatarUrl       String?   @map("avatar_url")
  isActive        Boolean   @default(true) @map("is_active")
  // Campos de convite para o Professional Access
  inviteToken     String?   @unique @map("invite_token")
  inviteExpiresAt DateTime? @map("invite_expires_at")
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  organization           Organization              @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                   User?                     @relation("ProfessionalUser", fields: [userId], references: [id], onDelete: SetNull)
  workingHours           WorkingHours[]
  workingHoursExceptions WorkingHoursException[]
  appointments           Appointment[]
  professionalServices   ProfessionalService[]
  // Unique por (organizationId, professionalId) — 1 entrada por org, mas Prisma trata como 1:many
  manualOrders           ManualProfessionalOrder[]

  @@index([organizationId, isActive])
  @@map("professionals")
}

model ServiceCategory {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  name           String
  isActive       Boolean  @default(true) @map("is_active")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  services     Service[]

  @@unique([organizationId, name])
  @@index([organizationId, isActive])
  @@map("service_categories")
}

model Service {
  id             String                 @id @default(uuid())
  organizationId String                 @map("organization_id")
  categoryId     String?                @map("category_id")
  name           String
  // Duração em minutos — granularidade mínima de agendamento
  duration       Int
  price          Decimal                @db.Decimal(15, 2)
  isActive       Boolean                @default(true) @map("is_active")
  // Embedding pgvector (1536 dims, text-embedding-3-small) — gerado a partir do name
  // para busca semântica via tool search_service do agente IA.
  embedding      Unsupported("vector")? @map("embedding")
  createdAt      DateTime               @default(now()) @map("created_at")
  updatedAt      DateTime               @updatedAt @map("updated_at")

  organization         Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  category             ServiceCategory?      @relation(fields: [categoryId], references: [id])
  professionalServices ProfessionalService[]
  appointments         Appointment[]
  dealLineItems        DealLineItem[]
  promotionItems       PromotionItem[]

  @@index([organizationId, isActive])
  @@index([categoryId])
  @@map("services")
}

model ProfessionalService {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  professionalId String   @map("professional_id")
  serviceId      String   @map("service_id")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)
  service      Service      @relation(fields: [serviceId], references: [id], onDelete: Cascade)

  @@unique([professionalId, serviceId])
  @@index([serviceId])
  @@index([organizationId])
  @@map("professional_services")
}

model WorkingHours {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  professionalId String   @map("professional_id")
  // 0 = domingo, 6 = sábado (alinhado com Date.getDay() do JS)
  dayOfWeek      Int      @map("day_of_week")
  // Strings "HH:mm" — armazenamento em string evita timezone drift
  startTime      String   @map("start_time")
  endTime        String   @map("end_time")
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, dayOfWeek])
  @@index([organizationId])
  @@map("working_hours")
}

model WorkingHoursException {
  id             String                    @id @default(uuid())
  organizationId String                    @map("organization_id")
  professionalId String                    @map("professional_id")
  // Data da exceção (apenas DATE, sem horário)
  date           DateTime                  @db.Date
  type           WorkingHoursExceptionType
  // Quando type = CUSTOM_HOURS, ambos preenchidos. Quando OFF, ambos null.
  startTime      String?                   @map("start_time")
  endTime        String?                   @map("end_time")
  createdAt      DateTime                  @default(now()) @map("created_at")
  updatedAt      DateTime                  @updatedAt @map("updated_at")

  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([professionalId, date])
  @@index([organizationId, date])
  @@map("working_hours_exceptions")
}

model ManualProfessionalOrder {
  id             String   @id @default(uuid())
  organizationId String   @map("organization_id")
  professionalId String   @map("professional_id")
  // Posição na fila (1 = primeiro)
  order          Int
  createdAt      DateTime @default(now()) @map("created_at")
  updatedAt      DateTime @updatedAt @map("updated_at")

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  professional Professional @relation(fields: [professionalId], references: [id], onDelete: Cascade)

  @@unique([organizationId, professionalId])
  @@unique([organizationId, order])
  @@map("manual_professional_orders")
}

