generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String            @id @default(uuid())
  email                   String            @unique
  fullName                String?           @map("full_name")
  avatarUrl               String?           @map("avatar_url")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  phone                   String?
  notificationPreferences Json?             @map("notification_preferences")
  isSuperAdmin            Boolean           @default(false) @map("is_super_admin")
  activitiesPerformed     Activity[]        @relation("ActivityPerformer")
  announcements           Announcement[]
  appointments            Appointment[]     @relation("AppointmentAssignee")
  contactsAssigned        Contact[]         @relation("ContactAssignee")
  conversationsAssigned   Conversation[]    @relation("ConversationAssignee")
  dealsAssigned           Deal[]            @relation("DealAssignee")
  memberships             Member[]
  notifications           Notification[]
  tasksAssigned           Task[]            @relation("TaskAssignee")
  tasksCreated            Task[]            @relation("TaskCreator")
  integrations            UserIntegration[]

  @@map("users")
}

model Organization {
  id                     String                  @id @default(uuid())
  name                   String
  slug                   String                  @unique
  stripeCustomerId       String?                 @unique @map("stripe_customer_id")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  billingCity            String?                 @map("billing_city")
  billingComplement      String?                 @map("billing_complement")
  billingContactEmail    String?                 @map("billing_contact_email")
  billingContactName     String?                 @map("billing_contact_name")
  billingContactPhone    String?                 @map("billing_contact_phone")
  billingCountry         String?                 @default("BR") @map("billing_country")
  billingNeighborhood    String?                 @map("billing_neighborhood")
  billingNumber          String?                 @map("billing_number")
  billingState           String?                 @map("billing_state")
  billingStreet          String?                 @map("billing_street")
  billingZipCode         String?                 @map("billing_zip_code")
  isSimples              Boolean                 @default(false) @map("is_simples")
  legalName              String?                 @map("legal_name")
  personType             PersonType?             @map("person_type")
  taxId                  String?                 @map("tax_id")
  tradeName              String?                 @map("trade_name")
  trialEndsAt            DateTime?               @map("trial_ends_at")
  isReadOnly             Boolean                 @default(false) @map("is_read_only")
  grantType              GrantType?              @map("grant_type")
  planOverrideId         String?                 @map("plan_override_id")
  niche                  String?                 @map("niche")
  onboardingCompleted    Boolean                 @default(false) @map("onboarding_completed")
  agentExecutions        AgentExecution[]
  agentTestConversations AgentTestConversation[]
  agents                 Agent[]
  aiUsage                AiUsage[]
  appointments           Appointment[]
  companies              Company[]
  contacts               Contact[]
  conversations          Conversation[]
  creditWallet           CreditWallet?
  lostReasons            DealLostReason[]
  Deal                   Deal[]
  inboxes                Inbox[]
  members                Member[]
  notifications          Notification[]
  planOverride           Plan?                   @relation("PlanOverride", fields: [planOverrideId], references: [id])
  pipelines              Pipeline[]
  products               Product[]
  productMedia           ProductMedia[]
  subscriptions          Subscription[]
  tasks                  Task[]
  userIntegrations       UserIntegration[]
  followUps              FollowUp[]

  @@map("organizations")
}

model Member {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  userId          String?      @map("user_id")
  email           String
  role            MemberRole   @default(MEMBER)
  status          MemberStatus @default(PENDING)
  invitationToken String?      @unique @map("invitation_token")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, status, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, organizationId])
  @@map("members")
}

model Subscription {
  id                   String             @id @default(uuid())
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  metadata             Json?
  organizationId       String             @map("organization_id")
  stripePriceId        String             @map("stripe_price_id")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  status               SubscriptionStatus @default(active)
  planId               String?            @map("plan_id")
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 Plan?              @relation(fields: [planId], references: [id])

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("subscriptions")
}

model Company {
  id             String       @id @default(uuid())
  name           String
  domain         String?
  industry       String?
  size           CompanySize?
  address        String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  deals          Deal[]

  @@index([organizationId, name])
  @@map("companies")
}

model Contact {
  id              String         @id @default(uuid())
  companyId       String?        @map("company_id")
  name            String
  email           String?
  phone           String?
  role            String?
  cpf             String?
  isDecisionMaker Boolean        @default(false) @map("is_decision_maker")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  organizationId  String         @map("organization_id")
  assignedTo      String?        @map("assigned_to")
  assignee        User?          @relation("ContactAssignee", fields: [assignedTo], references: [id])
  company         Company?       @relation(fields: [companyId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  deals           DealContact[]

  @@index([organizationId, assignedTo, createdAt(sort: Desc)])
  @@index([organizationId, name])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@index([companyId, organizationId])
  @@map("contacts")
}

model Pipeline {
  id             String          @id @default(uuid())
  name           String
  organizationId String          @map("organization_id")
  stages         PipelineStage[]
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("pipelines")
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String   @map("pipeline_id")
  name       String
  position   Int
  color      String?
  deals      Deal[]
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, position])
  @@map("pipeline_stages")
}

model Deal {
  id                String          @id @default(uuid())
  pipelineStageId   String          @map("pipeline_stage_id")
  companyId         String?         @map("company_id")
  title             String
  expectedCloseDate DateTime?       @map("expected_close_date")
  assignedTo        String          @map("assigned_to")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  lostReason        String?
  notes             String?
  pausedAt          DateTime?       @map("paused_at")
  priority          DealPriority    @default(medium)
  status            DealStatus      @default(OPEN)
  organizationId    String          @map("organization_id")
  lossReasonId      String?         @map("loss_reason_id")
  value             Decimal         @default(0) @db.Decimal(15, 2)
  activities        Activity[]
  appointments      Appointment[]
  conversations     Conversation[]
  contacts          DealContact[]
  dealProducts      DealProduct[]
  assignee          User            @relation("DealAssignee", fields: [assignedTo], references: [id])
  company           Company?        @relation(fields: [companyId], references: [id])
  lossReason        DealLostReason? @relation(fields: [lossReasonId], references: [id])
  organization      Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage             PipelineStage   @relation(fields: [pipelineStageId], references: [id])
  tasks             Task[]

  @@index([organizationId, pipelineStageId, assignedTo])
  @@index([organizationId, pipelineStageId, createdAt(sort: Desc)])
  @@index([organizationId, status, assignedTo])
  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("deals")
}

model Task {
  id             String       @id @default(uuid())
  dealId         String       @map("deal_id")
  title          String
  dueDate        DateTime     @map("due_date")
  isCompleted    Boolean      @default(false) @map("is_completed")
  assignedTo     String       @map("assigned_to")
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  type           TaskType     @default(TASK)
  organizationId String       @map("organization_id")
  assignee       User         @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator        User         @relation("TaskCreator", fields: [createdBy], references: [id])
  deal           Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assignedTo, isCompleted, dueDate])
  @@index([organizationId, isCompleted, dueDate])
  @@index([dealId, organizationId])
  @@map("tasks")
}

model Activity {
  id          String       @id @default(uuid())
  dealId      String       @map("deal_id")
  type        ActivityType
  content     String
  createdAt   DateTime     @default(now()) @map("created_at")
  performedBy String?      @map("performed_by")
  metadata    Json?
  deal        Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  performer   User?        @relation("ActivityPerformer", fields: [performedBy], references: [id])

  @@index([dealId, createdAt(sort: Desc)])
  @@map("activities")
}

model Appointment {
  id             String                @id @default(uuid())
  organizationId String                @map("organization_id")
  title          String
  description    String?
  startDate      DateTime              @map("start_date")
  endDate        DateTime              @map("end_date")
  status         AppointmentStatus     @default(SCHEDULED)
  assignedTo     String                @map("assigned_to")
  dealId         String                @map("deal_id")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  user           User                  @relation("AppointmentAssignee", fields: [assignedTo], references: [id])
  deal           Deal                  @relation(fields: [dealId], references: [id], onDelete: Cascade)
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncMappings   CalendarSyncMapping[]

  @@index([organizationId])
  @@index([assignedTo])
  @@index([dealId])
  @@map("appointments")
}

model Product {
  id             String                @id @default(uuid())
  name           String
  description    String?
  price          Decimal               @db.Decimal(15, 2)
  isActive       Boolean               @default(true) @map("is_active")
  createdAt      DateTime              @default(now()) @map("created_at")
  updatedAt      DateTime              @updatedAt @map("updated_at")
  organizationId String                @map("organization_id")
  embedding      Unsupported("vector")? @map("embedding")
  dealProducts   DealProduct[]
  media          ProductMedia[]
  organization   Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("products")
}

model ProductMedia {
  id             String           @id @default(uuid())
  productId      String           @map("product_id")
  organizationId String           @map("organization_id")
  type           ProductMediaType
  url            String
  storagePath    String           @map("storage_path")
  fileName       String           @map("file_name")
  mimeType       String           @map("mime_type")
  fileSize       Int              @map("file_size")
  order          Int              @default(0)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([productId, order])
  @@index([organizationId])
  @@map("product_media")
}

enum ProductMediaType {
  IMAGE
  VIDEO
}

model DealProduct {
  id            String       @id @default(uuid())
  dealId        String       @map("deal_id")
  productId     String       @map("product_id")
  quantity      Int          @default(1)
  unitPrice     Decimal      @map("unit_price") @db.Decimal(15, 2)
  discountType  DiscountType @default(percentage) @map("discount_type")
  discountValue Decimal      @default(0) @map("discount_value") @db.Decimal(15, 2)
  deal          Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  product       Product      @relation(fields: [productId], references: [id])

  @@index([dealId])
  @@index([productId])
  @@map("deal_products")
}

model DealContact {
  id        String  @id @default(uuid())
  dealId    String  @map("deal_id")
  contactId String  @map("contact_id")
  role      String?
  isPrimary Boolean @default(false) @map("is_primary")
  contact   Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal      Deal    @relation(fields: [dealId], references: [id], onDelete: Cascade)

  @@unique([dealId, contactId])
  @@index([contactId])
  @@map("deal_contacts")
}

model DealLostReason {
  id             String       @id @default(uuid())
  organizationId String       @map("organization_id")
  name           String
  isActive       Boolean      @default(true) @map("is_active")
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  deals          Deal[]

  @@index([organizationId, isActive, name])
  @@map("deal_lost_reasons")
}

model Feature {
  id          String           @id @default(uuid())
  key         String           @unique
  name        String
  description String?
  type        FeatureType      @default(STATIC)
  valueType   FeatureValueType @default(NUMBER) @map("value_type")
  createdAt   DateTime         @default(now()) @map("created_at")
  updatedAt   DateTime         @updatedAt @map("updated_at")
  moduleId    String?          @map("module_id")
  module      Module?          @relation(fields: [moduleId], references: [id])
  planLimits  PlanLimit[]

  @@index([moduleId])
  @@map("features")
}

model Plan {
  id                   String         @id @default(uuid())
  slug                 String         @unique
  name                 String
  stripeProductId      String?        @map("stripe_product_id")
  description          String?
  isActive             Boolean        @default(true) @map("is_active")
  createdAt            DateTime       @default(now()) @map("created_at")
  updatedAt            DateTime       @updatedAt @map("updated_at")
  grantedOrganizations Organization[] @relation("PlanOverride")
  planLimits           PlanLimit[]
  planModules          PlanModule[]
  subscriptions        Subscription[]

  @@index([slug, isActive])
  @@map("plans")
}

model PlanLimit {
  id           String   @id @default(uuid())
  planId       String   @map("plan_id")
  featureId    String   @map("feature_id")
  valueNumber  Int?     @map("value_number")
  valueBoolean Boolean? @map("value_boolean")
  valueString  String?  @map("value_string")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")
  feature      Feature  @relation(fields: [featureId], references: [id], onDelete: Cascade)
  plan         Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, featureId])
  @@index([featureId])
  @@map("plan_limits")
}

model CreditWallet {
  id                       String              @id @default(uuid())
  organizationId           String              @unique @map("organization_id")
  planBalance              Int                 @default(0) @map("plan_balance")
  topUpBalance             Int                 @default(0) @map("top_up_balance")
  autoRechargeEnabled      Boolean             @default(false) @map("auto_recharge_enabled")
  autoRechargeTrigger      Int                 @default(10) @map("auto_recharge_trigger")
  autoRechargeAmount       Int                 @default(100) @map("auto_recharge_amount")
  maxAutoRechargesPerMonth Int                 @default(5) @map("max_auto_recharges_per_month")
  createdAt                DateTime            @default(now()) @map("created_at")
  updatedAt                DateTime            @updatedAt @map("updated_at")
  organization             Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  transactions             WalletTransaction[]

  @@map("credit_wallets")
}

model WalletTransaction {
  id                String                @id @default(uuid())
  walletId          String                @map("wallet_id")
  type              WalletTransactionType
  amount            Int
  balanceAfterPlan  Int                   @map("balance_after_plan")
  balanceAfterTopUp Int                   @map("balance_after_top_up")
  description       String
  metadata          Json?
  createdAt         DateTime              @default(now()) @map("created_at")
  wallet            CreditWallet          @relation(fields: [walletId], references: [id], onDelete: Cascade)

  @@index([walletId, createdAt(sort: Desc)])
  @@map("wallet_transactions")
}

model AiUsage {
  id                String       @id @default(uuid())
  organizationId    String       @map("organization_id")
  totalMessagesUsed Int          @default(0) @map("total_messages_used")
  totalCreditsSpent Int          @default(0) @map("total_credits_spent")
  periodYear        Int          @map("period_year")
  periodMonth       Int          @map("period_month")
  createdAt         DateTime     @default(now()) @map("created_at")
  updatedAt         DateTime     @updatedAt @map("updated_at")
  organization      Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@unique([organizationId, periodYear, periodMonth])
  @@map("ai_usages")
}

model Module {
  id          String       @id @default(uuid())
  slug        String       @unique
  name        String
  isActive    Boolean      @default(true) @map("is_active")
  createdAt   DateTime     @default(now()) @map("created_at")
  updatedAt   DateTime     @updatedAt @map("updated_at")
  features    Feature[]
  planModules PlanModule[]

  @@index([slug, isActive])
  @@map("modules")
}

model PlanModule {
  id        String   @id @default(uuid())
  planId    String   @map("plan_id")
  moduleId  String   @map("module_id")
  createdAt DateTime @default(now()) @map("created_at")
  module    Module   @relation(fields: [moduleId], references: [id], onDelete: Cascade)
  plan      Plan     @relation(fields: [planId], references: [id], onDelete: Cascade)

  @@unique([planId, moduleId])
  @@index([moduleId])
  @@map("plan_modules")
}

model Agent {
  id                    String                  @id @default(uuid())
  organizationId        String                  @map("organization_id")
  name                  String
  systemPrompt          String                  @map("system_prompt")
  isActive              Boolean                 @default(true) @map("is_active")
  pipelineIds           String[]                @map("pipeline_ids") @db.Uuid
  createdAt             DateTime                @default(now()) @map("created_at")
  updatedAt             DateTime                @updatedAt @map("updated_at")
  debounceSeconds       Int                     @default(3) @map("debounce_seconds")
  modelId               String                  @default("google/gemini-2.5-pro") @map("model_id")
  businessHoursConfig   Json?                   @map("business_hours_config")
  businessHoursEnabled  Boolean                 @default(false) @map("business_hours_enabled")
  businessHoursTimezone String                  @default("America/Sao_Paulo") @map("business_hours_timezone")
  outOfHoursMessage                String?                 @map("out_of_hours_message")
  followUpBusinessHoursEnabled     Boolean                 @default(false) @map("follow_up_business_hours_enabled")
  followUpBusinessHoursConfig      Json?                   @map("follow_up_business_hours_config")
  followUpBusinessHoursTimezone    String                  @default("America/Sao_Paulo") @map("follow_up_business_hours_timezone")
  promptConfig                     Json?                   @map("prompt_config")
  followUpExhaustedAction          String                  @default("NONE") @map("follow_up_exhausted_action")
  followUpExhaustedConfig          Json?                   @map("follow_up_exhausted_config")
  executions            AgentExecution[]
  knowledgeChunks       AgentKnowledgeChunk[]
  knowledgeFiles        AgentKnowledgeFile[]
  steps                 AgentStep[]
  testConversations     AgentTestConversation[]
  organization          Organization            @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  inboxes               Inbox[]
  followUps             FollowUp[]

  @@index([organizationId, isActive])
  @@map("agents")
}

model AgentStep {
  id                    String                    @id @default(uuid())
  agentId               String                    @map("agent_id")
  name                  String
  objective             String
  allowedActions        String[]                  @default([]) @map("allowed_actions")
  activationRequirement String?                   @map("activation_requirement")
  order                 Int
  createdAt             DateTime                  @default(now()) @map("created_at")
  updatedAt             DateTime                  @updatedAt @map("updated_at")
  actions               Json?                     @map("actions")
  keyQuestion           String?                   @map("key_question")
  messageTemplate       String?                   @map("message_template")
  agent                 Agent                     @relation(fields: [agentId], references: [id], onDelete: Cascade)
  followUpLinks         FollowUpAgentStep[]

  @@index([agentId, order])
  @@map("agent_steps")
}

model AgentKnowledgeFile {
  id          String                @id @default(uuid())
  agentId     String                @map("agent_id")
  fileName    String                @map("file_name")
  fileSize    Int                   @map("file_size")
  mimeType    String                @map("mime_type")
  b2Url       String?               @map("b2_url")
  status      KnowledgeFileStatus   @default(PENDING)
  chunkCount  Int                   @default(0) @map("chunk_count")
  errorReason String?               @map("error_reason")
  createdAt   DateTime              @default(now()) @map("created_at")
  updatedAt   DateTime              @updatedAt @map("updated_at")
  chunks      AgentKnowledgeChunk[]
  agent       Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)

  @@index([agentId, status])
  @@map("agent_knowledge_files")
}

model AgentKnowledgeChunk {
  id        String                @id @default(uuid())
  fileId    String                @map("file_id")
  content   String
  embedding Unsupported("vector")
  metadata  Json?
  createdAt DateTime              @default(now()) @map("created_at")
  agentId   String                @map("agent_id")
  agent     Agent                 @relation(fields: [agentId], references: [id], onDelete: Cascade)
  file      AgentKnowledgeFile    @relation(fields: [fileId], references: [id], onDelete: Cascade)

  @@index([fileId])
  @@index([agentId])
  @@map("agent_knowledge_chunks")
}

model FollowUp {
  id             String              @id @default(uuid())
  agentId        String              @map("agent_id")
  organizationId String              @map("organization_id")
  delayMinutes   Int                 @map("delay_minutes")
  messageContent String              @map("message_content")
  order          Int                 @default(0)
  isActive       Boolean             @default(true) @map("is_active")
  createdAt      DateTime            @default(now()) @map("created_at")
  updatedAt      DateTime            @updatedAt @map("updated_at")

  agent          Agent               @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization   Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  agentStepLinks FollowUpAgentStep[]

  @@index([agentId, isActive])
  @@index([organizationId])
  @@map("follow_ups")
}

model FollowUpAgentStep {
  id          String    @id @default(uuid())
  followUpId  String    @map("follow_up_id")
  agentStepId String    @map("agent_step_id")

  followUp    FollowUp  @relation(fields: [followUpId], references: [id], onDelete: Cascade)
  agentStep   AgentStep @relation(fields: [agentStepId], references: [id], onDelete: Cascade)

  @@unique([followUpId, agentStepId])
  @@index([agentStepId])
  @@map("follow_up_agent_steps")
}

model Inbox {
  id                    String         @id @default(uuid())
  organizationId        String         @map("organization_id")
  name                  String
  channel               InboxChannel   @default(WHATSAPP)
  isActive              Boolean        @default(true) @map("is_active")
  evolutionInstanceName String?        @unique @map("evolution_instance_name")
  evolutionInstanceId   String?        @map("evolution_instance_id")
  evolutionConnected    Boolean        @default(false) @map("evolution_connected")
  agentId               String?        @map("agent_id")
  createdAt             DateTime       @default(now()) @map("created_at")
  updatedAt             DateTime       @updatedAt @map("updated_at")
  autoCreateDeal        Boolean        @default(true) @map("auto_create_deal")
  distributionUserIds   String[]       @map("distribution_user_ids") @db.Uuid
  pipelineId            String?        @map("pipeline_id") @db.Uuid
  connectionType        ConnectionType @default(EVOLUTION) @map("connection_type")
  metaAccessToken       String?        @map("meta_access_token")
  metaPhoneDisplay      String?        @map("meta_phone_display")
  metaPhoneNumberId     String?        @map("meta_phone_number_id")
  metaWabaId            String?        @map("meta_waba_id")
  zapiInstanceId        String?        @unique @map("zapi_instance_id")
  zapiToken             String?        @map("zapi_token")
  zapiClientToken       String?        @map("zapi_client_token")
  conversations         Conversation[]
  agent                 Agent?         @relation(fields: [agentId], references: [id], onDelete: SetNull)
  organization          Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@index([agentId])
  @@index([metaPhoneNumberId])
  @@index([zapiInstanceId])
  @@map("inboxes")
}

model Conversation {
  id                     String              @id @default(uuid())
  inboxId                String              @map("inbox_id")
  organizationId         String              @map("organization_id")
  contactId              String              @map("contact_id")
  dealId                 String?             @map("deal_id")
  // Responsável pela conversa — herdado do contato na criação, usado para filtro RBAC (MEMBER)
  assignedTo             String?             @map("assigned_to")
  channel                InboxChannel        @default(WHATSAPP)
  aiPaused               Boolean             @default(false) @map("ai_paused")
  pausedAt               DateTime?           @map("paused_at")
  remoteJid              String?             @map("remote_jid")
  summary                String?
  currentStepOrder       Int                 @default(0) @map("current_step_order")
  unreadCount            Int                 @default(0) @map("unread_count")
  // Role da última mensagem da conversa (denormalizado para filtro "não respondidos")
  lastMessageRole        String?             @map("last_message_role")
  // Fixar conversa no topo — null = não fixada, preenchido = fixada (serve como flag E timestamp)
  pinnedAt               DateTime?           @map("pinned_at")
  createdAt              DateTime            @default(now()) @map("created_at")
  updatedAt              DateTime            @updatedAt @map("updated_at")
  nextFollowUpAt         DateTime?           @map("next_follow_up_at")
  followUpCount          Int                 @default(0) @map("follow_up_count")
  agentExecutions        AgentExecution[]
  events                 ConversationEvent[]
  assignee               User?               @relation("ConversationAssignee", fields: [assignedTo], references: [id])
  contact                Contact             @relation(fields: [contactId], references: [id], onDelete: Cascade)
  deal                   Deal?               @relation(fields: [dealId], references: [id])
  inbox                  Inbox               @relation(fields: [inboxId], references: [id], onDelete: Cascade)
  organization           Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages               Message[]

  @@unique([inboxId, contactId, channel])
  @@index([organizationId, inboxId])
  @@index([organizationId, assignedTo])
  @@index([contactId])
  @@index([remoteJid, inboxId])
  @@index([dealId])
  @@index([nextFollowUpAt, aiPaused])
  // Índice composto para a query "não respondidos": WHERE org = X AND last_message_role = 'user' ORDER BY updated_at DESC
  @@index([organizationId, lastMessageRole, updatedAt(sort: Desc)])
  @@map("conversations")
}

model Message {
  id                String       @id @default(uuid())
  conversationId    String       @map("conversation_id")
  role              MessageRole
  content           String
  providerMessageId String?      @unique @map("provider_message_id")
  isArchived        Boolean      @default(false) @map("is_archived")
  inputTokens       Int?         @map("input_tokens")
  outputTokens      Int?         @map("output_tokens")
  metadata          Json?
  createdAt         DateTime     @default(now()) @map("created_at")
  conversation      Conversation @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, isArchived, createdAt(sort: Desc)])
  @@map("messages")
}

model ConversationEvent {
  id             String                @id @default(uuid())
  conversationId String                @map("conversation_id")
  type           ConversationEventType
  toolName       String?               @map("tool_name")
  content        String
  metadata       Json?
  visibleToUser  Boolean               @default(true) @map("visible_to_user")
  createdAt      DateTime              @default(now()) @map("created_at")
  conversation   Conversation          @relation(fields: [conversationId], references: [id], onDelete: Cascade)

  @@index([conversationId, createdAt(sort: Desc)])
  @@map("conversation_events")
}

model AgentTestConversation {
  id               String             @id @default(uuid())
  agentId          String             @map("agent_id")
  organizationId   String             @map("organization_id")
  userId           String             @map("user_id")
  currentStepOrder Int                @default(0) @map("current_step_order")
  summary          String?
  createdAt        DateTime           @default(now()) @map("created_at")
  updatedAt        DateTime           @updatedAt @map("updated_at")
  agent            Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization     Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  messages         AgentTestMessage[]

  @@unique([agentId, userId])
  @@index([organizationId])
  @@map("agent_test_conversations")
}

model AgentTestMessage {
  id                 String                @id @default(uuid())
  testConversationId String                @map("test_conversation_id")
  role               MessageRole
  content            String
  inputTokens        Int?                  @map("input_tokens")
  outputTokens       Int?                  @map("output_tokens")
  metadata           Json?
  createdAt          DateTime              @default(now()) @map("created_at")
  testConversation   AgentTestConversation @relation(fields: [testConversationId], references: [id], onDelete: Cascade)

  @@index([testConversationId, createdAt(sort: Desc)])
  @@map("agent_test_messages")
}

model AgentExecution {
  id               String                @id @default(uuid())
  agentId          String                @map("agent_id")
  organizationId   String                @map("organization_id")
  conversationId   String                @map("conversation_id")
  triggerMessageId String?               @map("trigger_message_id")
  status           AgentExecutionStatus
  startedAt        DateTime              @map("started_at")
  completedAt      DateTime?             @map("completed_at")
  durationMs       Int?                  @map("duration_ms")
  modelId          String?               @map("model_id")
  inputTokens      Int?                  @map("input_tokens")
  outputTokens     Int?                  @map("output_tokens")
  creditsCost      Int?                  @map("credits_cost")
  errorMessage     String?               @map("error_message")
  createdAt        DateTime              @default(now()) @map("created_at")
  updatedAt        DateTime              @updatedAt @map("updated_at")

  agent        Agent              @relation(fields: [agentId], references: [id], onDelete: Cascade)
  organization Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversation Conversation       @relation(fields: [conversationId], references: [id], onDelete: Cascade)
  steps        AgentExecutionStep[]

  @@index([agentId, createdAt(sort: Desc)])
  @@index([organizationId, agentId, status])
  @@index([conversationId])
  @@map("agent_executions")
}

model AgentExecutionStep {
  id          String                   @id @default(uuid())
  executionId String                   @map("execution_id")
  order       Int
  type        AgentExecutionStepType
  status      AgentExecutionStepStatus
  toolName    String?                  @map("tool_name")
  input       Json?
  output      Json?
  durationMs  Int?                     @map("duration_ms")
  createdAt   DateTime                 @default(now()) @map("created_at")

  execution AgentExecution @relation(fields: [executionId], references: [id], onDelete: Cascade)

  @@index([executionId, order])
  @@map("agent_execution_steps")
}

model UserIntegration {
  id                    String                @id @default(uuid())
  userId                String                @map("user_id")
  organizationId        String                @map("organization_id")
  provider              IntegrationProvider
  status                IntegrationStatus     @default(ACTIVE)
  accessTokenEncrypted  String                @map("access_token_encrypted")
  refreshTokenEncrypted String                @map("refresh_token_encrypted")
  tokenExpiresAt        DateTime              @map("token_expires_at")
  scope                 String
  providerAccountId     String?               @map("provider_account_id")
  providerMetadata      Json?                 @map("provider_metadata")
  lastSyncAt            DateTime?             @map("last_sync_at")
  syncError             String?               @map("sync_error")
  createdAt             DateTime              @default(now()) @map("created_at")
  updatedAt             DateTime              @updatedAt @map("updated_at")
  syncMappings          CalendarSyncMapping[]
  organization          Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user                  User                  @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([userId, organizationId, provider])
  @@index([organizationId, provider, status])
  @@index([userId, provider])
  @@map("user_integrations")
}

model CalendarSyncMapping {
  id                 String          @id @default(uuid())
  integrationId      String          @map("integration_id")
  appointmentId      String          @map("appointment_id")
  externalEventId    String          @map("external_event_id")
  externalCalendarId String          @map("external_calendar_id")
  direction          SyncDirection   @default(CRM_TO_EXTERNAL)
  lastSyncedAt       DateTime        @map("last_synced_at")
  externalUpdatedAt  DateTime?       @map("external_updated_at")
  checksum           String?
  createdAt          DateTime        @default(now()) @map("created_at")
  updatedAt          DateTime        @updatedAt @map("updated_at")
  appointment        Appointment     @relation(fields: [appointmentId], references: [id], onDelete: Cascade)
  integration        UserIntegration @relation(fields: [integrationId], references: [id], onDelete: Cascade)

  @@unique([integrationId, appointmentId])
  @@unique([integrationId, externalEventId])
  @@index([appointmentId])
  @@map("calendar_sync_mappings")
}

model Announcement {
  id              String   @id @default(uuid())
  title           String
  body            String
  actionUrl       String?  @map("action_url")
  targetOrgIds    String[] @default([]) @map("target_org_ids")
  createdBy       String   @map("created_by")
  totalRecipients Int      @default(0) @map("total_recipients")
  createdAt       DateTime @default(now()) @map("created_at")
  createdByUser   User     @relation(fields: [createdBy], references: [id])

  @@index([createdAt(sort: Desc)])
  @@map("announcements")
}

model Notification {
  id             String           @id @default(uuid())
  organizationId String           @map("organization_id")
  userId         String           @map("user_id")
  type           NotificationType
  title          String
  body           String
  actionUrl      String?          @map("action_url")
  resourceType   String?          @map("resource_type")
  resourceId     String?          @map("resource_id")
  readAt         DateTime?        @map("read_at")
  createdAt      DateTime         @default(now()) @map("created_at")
  organization   Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user           User             @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, readAt, createdAt(sort: Desc)])
  @@index([organizationId, userId, createdAt(sort: Desc)])
  @@map("notifications")
}

