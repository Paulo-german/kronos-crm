generator client {
  provider      = "prisma-client-js"
  binaryTargets = ["native", "debian-openssl-3.0.x"]
}

datasource db {
  provider  = "postgresql"
  url       = env("DATABASE_URL")
  directUrl = env("DIRECT_URL")
}

model User {
  id                      String            @id @default(uuid())
  email                   String            @unique
  fullName                String?           @map("full_name")
  avatarUrl               String?           @map("avatar_url")
  createdAt               DateTime          @default(now()) @map("created_at")
  updatedAt               DateTime          @updatedAt @map("updated_at")
  phone                   String?
  notificationPreferences Json?             @map("notification_preferences")
  isSuperAdmin            Boolean           @default(false) @map("is_super_admin")
  isSupportAgent          Boolean           @default(false) @map("is_support_agent")
  activitiesPerformed     Activity[]        @relation("ActivityPerformer")
  announcements           Announcement[]
  appointments            Appointment[]     @relation("AppointmentAssignee")
  contactsAssigned        Contact[]         @relation("ContactAssignee")
  conversationsAssigned   Conversation[]    @relation("ConversationAssignee")
  dealsAssigned           Deal[]            @relation("DealAssignee")
  memberships             Member[]
  notifications           Notification[]
  tasksAssigned           Task[]            @relation("TaskAssignee")
  tasksCreated            Task[]            @relation("TaskCreator")
  integrations            UserIntegration[]
  automationsCreated      Automation[]      @relation("AutomationCreator")
  userProfiles            UserProfile[]
  tutorialCompletions     TutorialCompletion[]
  changelogEntries        ChangelogEntry[]
  professional            Professional?     @relation("ProfessionalUser")
  goals                   Goal[]

  @@map("users")
}

model Organization {
  id                     String                  @id @default(uuid())
  name                   String
  slug                   String                  @unique
  website                String?                 @map("website")
  stripeCustomerId       String?                 @unique @map("stripe_customer_id")
  createdAt              DateTime                @default(now()) @map("created_at")
  updatedAt              DateTime                @updatedAt @map("updated_at")
  billingCity            String?                 @map("billing_city")
  billingComplement      String?                 @map("billing_complement")
  billingContactEmail    String?                 @map("billing_contact_email")
  billingContactName     String?                 @map("billing_contact_name")
  billingContactPhone    String?                 @map("billing_contact_phone")
  billingCountry         String?                 @default("BR") @map("billing_country")
  billingNeighborhood    String?                 @map("billing_neighborhood")
  billingNumber          String?                 @map("billing_number")
  billingState           String?                 @map("billing_state")
  billingStreet          String?                 @map("billing_street")
  billingZipCode         String?                 @map("billing_zip_code")
  isSimples              Boolean                 @default(false) @map("is_simples")
  legalName              String?                 @map("legal_name")
  personType             PersonType?             @map("person_type")
  taxId                  String?                 @map("tax_id")
  tradeName              String?                 @map("trade_name")
  trialEndsAt            DateTime?               @map("trial_ends_at")
  isReadOnly             Boolean                 @default(false) @map("is_read_only")
  grantType              GrantType?              @map("grant_type")
  planOverrideId         String?                 @map("plan_override_id")
  niche                  String?                 @map("niche")
  onboardingCompleted    Boolean                 @default(false) @map("onboarding_completed")
  hidePiiFromMembers     Boolean                 @default(false) @map("hide_pii_from_members")
  businessModel      BusinessModel @default(B2C) @map("business_model")
  dormantAfterMonths Int           @default(12)  @map("dormant_after_months")
  bookingAutoDeal    Boolean       @default(false) @map("booking_auto_deal")
  facilitatorDealWonToCustomer  Boolean                @default(true) @map("facilitator_deal_won_to_customer")
  facilitatorDealCreatedToOppty Boolean                @default(true) @map("facilitator_deal_created_to_oppty")
  salesDistributionModel        SalesDistributionModel @default(ROUND_ROBIN) @map("sales_distribution_model")
  agentExecutions        AgentExecution[]
  agentGroups            AgentGroup[]
  agentTestConversations AgentTestConversation[]
  agents                 Agent[]
  aiUsage                AiUsage[]
  appointments           Appointment[]
  companies              Company[]
  contacts               Contact[]
  conversations          Conversation[]
  creditWallet           CreditWallet?
  lostReasons            DealLostReason[]
  Deal                   Deal[]
  inboxes                Inbox[]
  members                Member[]
  notifications          Notification[]
  planOverride           Plan?                   @relation("PlanOverride", fields: [planOverrideId], references: [id])
  pipelines              Pipeline[]
  goals                  Goal[]
  products               Product[]
  productMedia           ProductMedia[]
  subscriptions          Subscription[]
  tasks                  Task[]
  userIntegrations       UserIntegration[]
  followUps                    FollowUp[]
  automations                  Automation[]
  automationExecutions         AutomationExecution[]
  conversationLabels           ConversationLabel[]
  userProfiles                 UserProfile[]
  tutorialCompletions          TutorialCompletion[]
  // Scheduling v2
  distributionModel            DistributionModel  @default(UTILIZATION) @map("distribution_model")
  secondaryDistributionModel   DistributionModel? @map("secondary_distribution_model")
  professionals                Professional[]
  serviceCategories            ServiceCategory[]
  services                     Service[]
  manualProfessionalOrders     ManualProfessionalOrder[]
  promotions                   Promotion[]
  dealLineItems                DealLineItem[]
  captureSources               CaptureSource[]
  campaigns                    Campaign[]
  captureEvents                CaptureEvent[]
  lifecycleHistory             ContactLifecycleHistory[]
  scoreHistory                 ContactScoreHistory[]
  companyContacts              CompanyContact[]

  @@map("organizations")
}

model Member {
  id              String       @id @default(uuid())
  organizationId  String       @map("organization_id")
  userId          String?      @map("user_id")
  email           String
  role            MemberRole   @default(MEMBER)
  status          MemberStatus @default(PENDING)
  invitationToken String?      @unique @map("invitation_token")
  createdAt       DateTime     @default(now()) @map("created_at")
  updatedAt       DateTime     @updatedAt @map("updated_at")
  organization    Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user            User?        @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([organizationId, email])
  @@index([organizationId, status, createdAt])
  @@index([userId, status, createdAt])
  @@index([userId, organizationId])
  @@map("members")
}

model Subscription {
  id                   String             @id @default(uuid())
  stripeSubscriptionId String             @unique @map("stripe_subscription_id")
  currentPeriodEnd     DateTime           @map("current_period_end")
  cancelAtPeriodEnd    Boolean            @default(false) @map("cancel_at_period_end")
  createdAt            DateTime           @default(now()) @map("created_at")
  metadata             Json?
  organizationId       String             @map("organization_id")
  stripePriceId        String             @map("stripe_price_id")
  updatedAt            DateTime           @updatedAt @map("updated_at")
  status               SubscriptionStatus @default(active)
  planId               String?            @map("plan_id")
  organization         Organization       @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  plan                 Plan?              @relation(fields: [planId], references: [id])

  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("subscriptions")
}

model Company {
  id             String       @id @default(uuid())
  name           String
  domain         String?
  cnpj           String?
  segment        String?
  industry       String?
  size           CompanySize?
  address        String?
  createdAt      DateTime     @default(now()) @map("created_at")
  updatedAt      DateTime     @updatedAt @map("updated_at")
  organizationId String       @map("organization_id")
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  contacts       Contact[]
  deals          Deal[]
  companyContacts CompanyContact[]

  @@index([organizationId, name])
  @@index([organizationId, cnpj])
  @@index([organizationId, domain])
  @@map("companies")
}

model Contact {
  id              String         @id @default(uuid())
  companyId       String?        @map("company_id")
  name            String
  email           String?
  phone           String?
  role            String?
  cpf             String?
  isDecisionMaker Boolean        @default(false) @map("is_decision_maker")
  createdAt       DateTime       @default(now()) @map("created_at")
  updatedAt       DateTime       @updatedAt @map("updated_at")
  organizationId  String         @map("organization_id")
  assignedTo      String?        @map("assigned_to")
  lifecycleStage      LifecycleStage  @default(LEAD)         @map("lifecycle_stage")
  customerStatus      CustomerStatus  @default(NEVER_BOUGHT) @map("customer_status")
  firstCaptureChannel CaptureChannel? @map("first_capture_channel")
  firstCaptureAt      DateTime?       @map("first_capture_at")
  lastCaptureChannel  CaptureChannel? @map("last_capture_channel")
  lastCaptureAt       DateTime?       @map("last_capture_at")
  healthScore         Float?          @map("health_score")
  scoredAt            DateTime?       @map("scored_at")
  lastInteractionAt   DateTime?       @map("last_interaction_at")
  qualifiedAt         DateTime?       @map("qualified_at")
  becameOpportunityAt DateTime?       @map("became_opportunity_at")
  becameCustomerAt    DateTime?       @map("became_customer_at")
  assignee        User?          @relation("ContactAssignee", fields: [assignedTo], references: [id])
  company         Company?       @relation(fields: [companyId], references: [id])
  organization    Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  conversations   Conversation[]
  deals           DealContact[]
  appointments    Appointment[]
  captureEvents   CaptureEvent[] @relation("ContactCaptureEvents")
  referrals       CaptureEvent[] @relation("ReferredByContact")
  lifecycleHistory ContactLifecycleHistory[]
  scoreHistory     ContactScoreHistory[]
  companies        CompanyContact[]

  @@index([organizationId, assignedTo, createdAt(sort: Desc)])
  @@index([organizationId, name])
  @@index([organizationId, email])
  @@index([organizationId, phone])
  @@index([companyId, organizationId])
  @@index([organizationId, lifecycleStage, updatedAt(sort: Desc)])
  @@index([organizationId, customerStatus])
  @@index([organizationId, healthScore(sort: Desc)])
  @@index([organizationId, lastCaptureAt(sort: Desc)])
  @@index([organizationId, lastInteractionAt(sort: Desc)])
  @@map("contacts")
}

model Pipeline {
  id             String          @id @default(uuid())
  name           String
  organizationId String          @map("organization_id")
  showIdleDays   Boolean         @default(true) @map("show_idle_days")
  isDefault      Boolean         @default(false) @map("is_default")
  createdAt      DateTime        @default(now()) @map("created_at")
  updatedAt      DateTime        @updatedAt @map("updated_at")
  stages         PipelineStage[]
  organization   Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  goals          Goal[]

  @@index([organizationId])
  @@map("pipelines")
}

model Goal {
  id             String     @id @default(uuid())
  organizationId String     @map("organization_id")

  type        GoalType
  scope       GoalScope
  period      GoalPeriod
  periodStart DateTime   @map("period_start")
  periodEnd   DateTime   @map("period_end")

  targetUserId     String?  @map("target_user_id")
  targetPipelineId String?  @map("target_pipeline_id")

  targetValue Decimal  @db.Decimal(15, 2) @map("target_value")
  createdBy   String   @map("created_by")

  organization   Organization  @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  targetUser     User?         @relation(fields: [targetUserId], references: [id], onDelete: SetNull)
  targetPipeline Pipeline?     @relation(fields: [targetPipelineId], references: [id], onDelete: SetNull)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([organizationId, type, periodStart, periodEnd])
  @@index([organizationId, scope, targetUserId, targetPipelineId])
  @@map("goals")
}

model CaptureSource {
  id              String         @id @default(uuid())
  organizationId  String         @map("organization_id")
  channel         CaptureChannel
  name            String
  isActive        Boolean        @default(true)  @map("is_active")
  isAdHoc         Boolean        @default(false) @map("is_ad_hoc")
  createdByUserId String?        @map("created_by_user_id")
  deactivatedAt   DateTime?      @map("deactivated_at")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       CaptureEvent[]
  inboxes      Inbox[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([organizationId, channel, isActive])
  @@index([organizationId, isAdHoc])
  @@map("capture_sources")
}

model Campaign {
  id               String         @id @default(uuid())
  organizationId   String         @map("organization_id")
  name             String
  channel          CaptureChannel
  utmCampaign      String?        @map("utm_campaign")
  externalId       String?        @map("external_id")
  externalPlatform String?        @map("external_platform")
  budget           Decimal?       @db.Decimal(15, 2)
  startDate        DateTime?      @map("start_date")
  endDate          DateTime?      @map("end_date")

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  events       CaptureEvent[]

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([organizationId, channel])
  @@index([organizationId, utmCampaign])
  @@map("campaigns")
}

model CaptureEvent {
  id                    String         @id @default(uuid())
  contactId             String         @map("contact_id")
  organizationId        String         @map("organization_id")
  channel               CaptureChannel
  sourceId              String         @map("source_id")
  sourceUrl             String?        @map("source_url")
  utmSource             String?        @map("utm_source")
  utmMedium             String?        @map("utm_medium")
  utmCampaign           String?        @map("utm_campaign")
  campaignId            String?        @map("campaign_id")
  referredByContactId   String?        @map("referred_by_contact_id")
  capturedAutomatically Boolean        @map("captured_automatically")
  metadata              Json           @default("{}")

  contact      Contact       @relation("ContactCaptureEvents", fields: [contactId],           references: [id], onDelete: Cascade)
  organization Organization  @relation(fields: [organizationId],  references: [id], onDelete: Cascade)
  source       CaptureSource @relation(fields: [sourceId],        references: [id], onDelete: Restrict)
  campaign     Campaign?     @relation(fields: [campaignId],      references: [id])
  referredBy   Contact?      @relation("ReferredByContact",       fields: [referredByContactId], references: [id], onDelete: SetNull)
  deals        DealCaptureEvent[]

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt(sort: Desc)])
  @@index([organizationId, channel, createdAt(sort: Desc)])
  @@index([organizationId, campaignId])
  @@index([organizationId, sourceId])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("capture_events")
}

model ContactLifecycleHistory {
  id             String             @id @default(uuid())
  contactId      String             @map("contact_id")
  organizationId String             @map("organization_id")

  fromStage       LifecycleStage?    @map("from_stage")
  toStage         LifecycleStage     @map("to_stage")
  causeType       LifecycleCauseType @map("cause_type")
  causeRefId      String?            @map("cause_ref_id")
  changedByUserId String?            @map("changed_by_user_id")

  contact      Contact      @relation(fields: [contactId],      references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt(sort: Desc)])
  @@index([organizationId, toStage, createdAt(sort: Desc)])
  @@map("contact_lifecycle_history")
}

model ContactScoreHistory {
  id             String   @id @default(uuid())
  contactId      String   @map("contact_id")
  organizationId String   @map("organization_id")

  score    Float
  snapshot Json  @default("{}")

  contact      Contact      @relation(fields: [contactId],      references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@index([contactId, createdAt(sort: Desc)])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("contact_score_history")
}

model CompanyContact {
  id             String   @id @default(uuid())
  companyId      String   @map("company_id")
  contactId      String   @map("contact_id")
  organizationId String   @map("organization_id")

  role      String?
  isPrimary Boolean   @default(false) @map("is_primary")
  startDate DateTime? @map("start_date")
  endDate   DateTime? @map("end_date")

  company      Company      @relation(fields: [companyId],      references: [id], onDelete: Cascade)
  contact      Contact      @relation(fields: [contactId],      references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt      @map("updated_at")

  @@index([companyId, isPrimary])
  @@index([contactId, endDate])
  @@index([organizationId, companyId])
  @@map("company_contacts")
}

model DealCaptureEvent {
  id             String          @id @default(uuid())
  dealId         String          @map("deal_id")
  captureEventId String          @map("capture_event_id")

  attribution DealAttribution
  weight      Float?

  removedAt DateTime? @map("removed_at")

  deal         Deal         @relation(fields: [dealId],         references: [id], onDelete: Cascade)
  captureEvent CaptureEvent @relation(fields: [captureEventId], references: [id], onDelete: Cascade)

  createdAt DateTime @default(now()) @map("created_at")

  @@unique([dealId, captureEventId])
  @@index([dealId, attribution])
  @@index([captureEventId])
  @@map("deal_capture_events")
}

model PipelineStage {
  id         String   @id @default(uuid())
  pipelineId String   @map("pipeline_id")
  name       String
  position   Int
  color      String?
  deals      Deal[]
  pipeline   Pipeline @relation(fields: [pipelineId], references: [id], onDelete: Cascade)

  @@index([pipelineId, position])
  @@map("pipeline_stages")
}

model Deal {
  id                String          @id @default(uuid())
  pipelineStageId   String          @map("pipeline_stage_id")
  companyId         String?         @map("company_id")
  title             String
  expectedCloseDate DateTime?       @map("expected_close_date")
  assignedTo        String          @map("assigned_to")
  createdAt         DateTime        @default(now()) @map("created_at")
  updatedAt         DateTime        @updatedAt @map("updated_at")
  lostReason        String?
  notes             String?
  pausedAt          DateTime?       @map("paused_at")
  priority          DealPriority    @default(medium)
  status            DealStatus      @default(OPEN)
  organizationId    String          @map("organization_id")
  lossReasonId      String?         @map("loss_reason_id")
  value             Decimal         @default(0) @db.Decimal(15, 2)
  mrr               Decimal         @default(0) @map("mrr") @db.Decimal(15, 2)
  activities           Activity[]
  appointments         Appointment[]
  conversations        Conversation[]
  contacts             DealContact[]
  dealProducts         DealProduct[]
  lineItems            DealLineItem[]
  assignee             User            @relation("DealAssignee", fields: [assignedTo], references: [id])
  company              Company?        @relation(fields: [companyId], references: [id])
  lossReason           DealLostReason? @relation(fields: [lossReasonId], references: [id])
  organization         Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  stage                PipelineStage   @relation(fields: [pipelineStageId], references: [id])
  tasks                Task[]
  automationExecutions AutomationExecution[]
  captureEvents        DealCaptureEvent[]

  @@index([organizationId, pipelineStageId, assignedTo])
  @@index([organizationId, pipelineStageId, createdAt(sort: Desc)])
  @@index([organizationId, status, assignedTo])
  @@index([organizationId, status, updatedAt(sort: Desc)])
  @@index([organizationId, status, createdAt(sort: Desc)])
  @@map("deals")
}

model Task {
  id             String       @id @default(uuid())
  dealId         String       @map("deal_id")
  title          String
  dueDate        DateTime     @map("due_date")
  isCompleted    Boolean      @default(false) @map("is_completed")
  assignedTo     String       @map("assigned_to")
  createdBy      String       @map("created_by")
  createdAt      DateTime     @default(now()) @map("created_at")
  type           TaskType     @default(TASK)
  organizationId String       @map("organization_id")
  assignee       User         @relation("TaskAssignee", fields: [assignedTo], references: [id])
  creator        User         @relation("TaskCreator", fields: [createdBy], references: [id])
  deal           Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  organization   Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId, assignedTo, isCompleted, dueDate])
  @@index([organizationId, isCompleted, dueDate])
  @@index([dealId, organizationId])
  @@map("tasks")
}

model Activity {
  id          String       @id @default(uuid())
  dealId      String       @map("deal_id")
  type        ActivityType
  content     String
  createdAt   DateTime     @default(now()) @map("created_at")
  performedBy String?      @map("performed_by")
  metadata    Json?
  deal        Deal         @relation(fields: [dealId], references: [id], onDelete: Cascade)
  performer   User?        @relation("ActivityPerformer", fields: [performedBy], references: [id])

  @@index([dealId, createdAt(sort: Desc)])
  @@map("activities")
}

model Appointment {
  id             String            @id @default(uuid())
  organizationId String            @map("organization_id")
  // Discrimina o tipo de agendamento: MEETING (deal-based, agenda comercial) ou BOOKING (profissional-based, agenda de entrega)
  type           AppointmentType   @default(MEETING) @map("type")
  title          String
  description    String?
  notes          String?
  startDate      DateTime          @map("start_date")
  endDate        DateTime          @map("end_date")
  status         AppointmentStatus @default(SCHEDULED)
  assignedTo     String            @map("assigned_to")
  // dealId virou opcional: obrigatório apenas para MEETING, enforced na application layer
  dealId         String?           @map("deal_id")
  // Novos campos de scheduling v2 — nullable permanentemente (obrigatoriedade na app layer)
  professionalId String?           @map("professional_id")
  serviceId      String?           @map("service_id")
  // contactId nullable nesta Fase A — será NOT NULL após backfill (Fase C)
  contactId      String?           @map("contact_id")
  // Snapshot do preço no momento do agendamento (apenas SERVICE)
  priceSnapshot  Decimal?          @map("price_snapshot") @db.Decimal(15, 2)
  paymentStatus  PaymentStatus?    @map("payment_status")
  createdAt      DateTime          @default(now()) @map("created_at")
  updatedAt      DateTime          @updatedAt @map("updated_at")

  user         User                  @relation("AppointmentAssignee", fields: [assignedTo], references: [id])
  // dealId: SetNull para não quebrar ao deletar deal órfão
  deal         Deal?                 @relation(fields: [dealId], references: [id], onDelete: SetNull)
  professional Professional?         @relation(fields: [professionalId], references: [id])
  service      Service?              @relation(fields: [serviceId], references: [id])
  contact      Contact?              @relation(fields: [contactId], references: [id])
  organization Organization          @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  syncMappings CalendarSyncMapping[]

  // Índice composto substitui [organizationId] isolado — mais seletivo para queries de agenda
  @@index([organizationId, startDate])
  @@index([professionalId, startDate])
  @@index([assignedTo])
  @@index([dealId])
  @@index([contactId])
  @@map("appointments")
}

model Product {
  id               String                 @id @default(uuid())
  name             String
  description      String?
  price            Decimal                @db.Decimal(15, 2)
  isActive         Boolean                @default(true) @map("is_active")
  createdAt        DateTime               @default(now()) @map("created_at")
  updatedAt        DateTime               @updatedAt @map("updated_at")
  organizationId   String                 @map("organization_id")
  embedding        Unsupported("vector")? @map("embedding")
  recurrenceType   RecurrenceType         @default(ONE_TIME) @map("recurrence_type")
  billingCycle     BillingCycle?          @map("billing_cycle")
  contractDuration Int?                   @map("contract_duration")
  dealProducts     DealProduct[]
  dealLineItems    DealLineItem[]
  promotionItems   PromotionItem[]
  media            ProductMedia[]
  organization     Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([organizationId])
  @@map("products")
}

model ProductMedia {
  id             String           @id @default(uuid())
  productId      String           @map("product_id")
  organizationId String           @map("organization_id")
  type           ProductMediaType
  url            String
  storagePath    String           @map("storage_path")
  fileName       String           @map("file_name")
  mimeType       String           @map("mime_type")
  fileSize       Int              @map("file_size")
  order          Int              @default(0)
  createdAt      DateTime         @default(now()) @map("created_at")
  updatedAt      DateTime         @updatedAt @map("updated_at")

  product      Product      @relation(fields: [productId], references: [id], onDelete: Cascade)
  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)

  @@index([productId, order])
  @@index([organizationId])
  @@map("product_media")
}

enum ProductMediaType {
  IMAGE
  VIDEO
