enum AutomationTrigger {
  DEAL_CREATED
  DEAL_MOVED
  // Nenhuma atividade por N minutos/horas/dias
  DEAL_STALE
  // Parado em um estágio específico por N tempo
  DEAL_IDLE_IN_STAGE
  // Qualquer atividade (nota, call, email, meeting, etc)
  ACTIVITY_CREATED
  // WON, LOST, PAUSED, OPEN (reaberto), etc
  DEAL_STATUS_CHANGED
}

enum AutomationAction {
  // Transfere deal para outro membro (round-robin ou específico)
  REASSIGN_DEAL
  MOVE_DEAL_TO_STAGE
  MARK_DEAL_LOST
  // Envia notificação in-app
  NOTIFY_USER
  UPDATE_DEAL_PRIORITY
  // Envia mensagem de follow-up via WhatsApp para o contato principal do deal
  SEND_WHATSAPP_FOLLOWUP
  // Avança o lifecycle stage dos contatos vinculados ao deal (monotônico)
  UPDATE_CONTACT_LIFECYCLE
}

enum AutomationExecutionStatus {
  SUCCESS
  FAILED
  // Condições não atendidas
  SKIPPED
}

model Automation {
  id              String              @id @default(uuid())
  organizationId  String              @map("organization_id")
  name            String
  description     String?
  isActive        Boolean             @default(true) @map("is_active")
  triggerType     AutomationTrigger   @map("trigger_type")
  triggerConfig   Json                @map("trigger_config")
  conditions      Json                @default("[]")
  actionType      AutomationAction    @map("action_type")
  actionConfig    Json                @map("action_config")
  createdBy       String              @map("created_by")
  lastTriggeredAt DateTime?           @map("last_triggered_at")
  executionCount  Int                 @default(0) @map("execution_count")
  createdAt       DateTime            @default(now()) @map("created_at")
  updatedAt       DateTime            @updatedAt @map("updated_at")

  organization    Organization        @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  creator         User                @relation("AutomationCreator", fields: [createdBy], references: [id])
  executions      AutomationExecution[]

  @@index([organizationId, isActive, triggerType])
  @@index([organizationId, createdAt(sort: Desc)])
  @@map("automations")
}

model AutomationExecution {
  id             String                    @id @default(uuid())
