  "Kronos: Server Action (padrão 6 passos)": {
    "prefix": "kact",
    "scope": "typescript",
    "description": "Server action no padrão 6 passos (RBAC, quota, ownership, DB, revalidateTag)",
    "body": [
      "'use server'",
      "",
      "import { orgActionClient } from '@/_lib/safe-action'",
      "import { ${1:entity}Schema } from './schema'",
      "import { db } from '@/_lib/prisma'",
      "import { revalidateTag } from 'next/cache'",
      "import {",
      "  canPerformAction,",
      "  requirePermission,",
      "  resolveAssignedTo,",
      "  requireQuota,",
      "} from '@/_lib/rbac'",
      "",
      "export const ${2:create}${3:Entity} = orgActionClient",
      "  .schema(${1:entity}Schema)",
      "  .action(async ({ parsedInput: data, ctx }) => {",
      "    // 1. RBAC: permissão base",
      "    requirePermission(canPerformAction(ctx, '${1:entity}', '${4:create}'))",
      "",
      "    // 2. Quota: limite do plano",
      "    await requireQuota(ctx.orgId, '${1:entity}')",
      "",
      "    // 3. Ownership: MEMBER forçado para si mesmo",
      "    const assignedTo = resolveAssignedTo(ctx, data.assignedTo)",
      "",
      "    // 4. Validação cross-entity",
      "    $5",
      "",
      "    // 5. Operação no banco",
      "    const ${6:record} = await db.${1:entity}.create({",
      "      data: {",
      "        organizationId: ctx.orgId,",
      "        assignedTo,",
      "        $0",
      "      },",
      "    })",
      "",
      "    // 6. Invalidar cache + retornar",
      "    revalidateTag(`${1:entity}s:\\${ctx.orgId}`)",
      "    return { success: true, ${6:record} }",
      "  })",
      ""
    ]
  },

