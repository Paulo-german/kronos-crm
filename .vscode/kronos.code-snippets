  "Kronos: Data Access (cacheado + RBAC)": {
    "prefix": "kdata",
    "scope": "typescript",
    "description": "Data-access com unstable_cache, cache key por userId e RBAC filter",
    "body": [
      "import 'server-only'",
      "import { unstable_cache } from 'next/cache'",
      "import { db } from '@/_lib/prisma'",
      "import type { RBACContext } from '@/_lib/rbac'",
      "import { isElevated } from '@/_lib/rbac'",
      "",
      "// Função base (sem cache)",
      "const fetch${1:Entities}FromDb = async (",
      "  orgId: string,",
      "  userId: string,",
      "  elevated: boolean,",
      ") => {",
      "  return db.${2:entity}.findMany({",
      "    where: {",
      "      organizationId: orgId,",
      "      // RBAC: MEMBER só vê os próprios registros",
      "      ...(elevated ? {} : { assignedTo: userId }),",
      "    },$0",
      "  })",
      "}",
      "",
      "// Wrapper com cache",
      "export const get${1:Entities} = async (ctx: RBACContext) => {",
      "  const elevated = isElevated(ctx.userRole)",
      "",
      "  const getCached = unstable_cache(",
      "    async () => fetch${1:Entities}FromDb(ctx.orgId, ctx.userId, elevated),",
      "    [`${2:entity}s-\\${ctx.orgId}-\\${ctx.userId}-\\${elevated}`],",
      "    {",
      "      tags: [`${2:entity}s:\\${ctx.orgId}`],",
      "      revalidate: 3600,",
      "    },",
      "  )",
      "",
      "  return getCached()",
      "}",
      ""
    ]
  },

